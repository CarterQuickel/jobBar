<link rel="stylesheet" href="/css/banner.css">
<header class="topHead">
    <div class="contain">
        <div class="offset">
            <div class="title">
                <img src="/icons/jobbar.png" width="38" height="38">
                <% if (typeof fb_id !== 'undefined' && fb_id) { %>
                    <strong class="proftxt" onclick="location.href='/profile'"><%= user && user.username ? user.username : 'Guest' %></strong>
                <% } %>
            </div>
            <div class="intC">
                <div class="buttonsCont">
                    <button class="redir" data-path="/allJobs" onclick="location.href='/allJobs'">
                        <img src="/icons/banner/issue.png" alt="All Issues" width="20" height="20">
                        <div>All Contracts</div>
                    </button>
                    <button class="redir" data-path="/companies" data-match="/companies,/Job,/eJob,/jobPosts,/jobManager,/ePost,/home,/positionManager" onclick="location.href='/companies'">
                        <img src="/icons/banner/company.png" alt="Companies" width="18" height="18">
                        <div>Companies
                                <%= (typeof company !== 'undefined' && company.name) ? ` / ${company.name}` : '' %>
                                <span id="page-type"></span>
                        </div>
                    </button>
                    <% if (isManager) { %>
                        <button class="redir" data-path="/post" onclick="location.href='/post'">
                            <img src="/icons/banner/create.png" alt="Create a Company" width="18" height="18">
                            <div>Create a Company</div>
                        </button>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
    <hr class="tophr">
</header>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const path = window.location.pathname;

        document.querySelectorAll(".redir").forEach(btn => {
            const base = btn.dataset.path;
            const matches = btn.dataset.match?.split(",") || [];

            if (
                path === base ||
                path.startsWith(base + "/") ||
                matches.some(m => path.startsWith(m))
            ) {
                btn.classList.add("active");
            }
        });
    });
    const path = window.location.pathname;
    const pageTypeEl = document.getElementById('page-type');

    if (path.includes('/eJob/')) pageTypeEl.textContent = ' / Positions';
    else if (path.includes('/Job/')) pageTypeEl.textContent = ' / Issues';
    else if (path.includes('jobPosts')) pageTypeEl.textContent = ' / Post Issue'
    else if (path.includes('/jobManager')) pageTypeEl.textContent = ' / Manage Issues'
    else if (path.includes('/ePost')) pageTypeEl.textContent = ' / Create Position'
    else if (path.includes('/positionManager')) pageTypeEl.textContent = ' / Manage Positions'
</script>